aws_region        = "us-east-1"
environment       = "dev"
db_name           = "shopcloud_orders"
db_username       = "shopcloud"
db_password       = "change-me-strong-password"
db_instance_class = "db.t3.micro"
redis_node_type   = "cache.t3.micro"
invoice_queue_name = "shopcloud-dev-invoice-queue"
invoice_bucket_name = "shopcloud-dev-invoices-680666325893"
enable_invoice_lambda_sqs_consumer = false
ses_from_email = "noreply@shopcloud-dev.example.com"
enable_rds_multi_az = true
enable_rds_cross_region_replica = false
dr_region = "us-west-2"
enable_redis_multi_az = false
enable_public_edge = false
enable_public_alb = false
root_domain_name = ""
public_hostname = ""
# Set this to the AWS Load Balancer Controller public ingress hostname (k8s/public-customer-ingress.yaml),
# or leave empty when public edge is disabled.
public_alb_dns_name = ""
# Optional: latency aliases (for multi-region endpoint strategy). Leave empty for single-alias mode.
public_latency_records = []
enable_private_admin_path = false
admin_vpn_server_certificate_arn           = ""
admin_vpn_client_root_certificate_chain_arn = ""
admin_vpn_client_cidr = "172.20.0.0/22"
enable_secrets_architecture = false
alarm_notification_topic_arn = ""
enable_alarm_notifications = false
alarm_notification_emails = []
